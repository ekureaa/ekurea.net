{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ekurea-net",
  "main": "src/worker.ts",
  "compatibility_date": "2026-05-24",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/photos/photos.json"
    ]
  },
  "vars": {
    "MEDIA_BASE_URL": "https://media.ekurea.net"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
