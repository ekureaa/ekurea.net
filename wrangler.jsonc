{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ekurea-net",
  "main": "src/worker.ts",
  "compatibility_date": "2026-05-24",
  "observability": {
    "enabled": true
  },
  "assets": {
    "binding": "ASSETS",
    "not_found_handling": "none",
    "run_worker_first": true
  },
  "vars": {
    "MEDIA_BASE_URL": "https://media.ekurea.net"
  }
}
