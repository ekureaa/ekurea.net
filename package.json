{
  "name": "ekurea-net-vue",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "photos:build": "node scripts/build-photos.mjs",
    "photos:upload": "node scripts/upload-media.mjs",
    "photos:publish": "npm run photos:build && npm run photos:upload -- --skip-uploaded",
    "photos:worker:deploy": "wrangler deploy -c workers/photo-publisher/wrangler.jsonc",
    "photos:worker:dev": "wrangler dev -c workers/photo-publisher/wrangler.jsonc",
    "blog:images:upload": "node scripts/upload-blog-images.mjs",
    "blog:publish": "npm run blog:images:upload && npm --prefix blog run generate:local",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "simple-icons": "^16.21.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@cloudflare/vite-plugin": "^1.38.0",
    "@tailwindcss/vite": "^4.1.12",
    "@vitejs/plugin-vue": "^5.2.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.6.3",
    "vite": "^6.3.5",
    "vue-tsc": "^2.2.0",
    "wrangler": "^4.94.0"
  }
}
